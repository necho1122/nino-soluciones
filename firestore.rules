rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ──────────────────────────────────────────────────────────

    // Admin = usuario autenticado con custom claim admin=true
    function isAdmin() {
      return request.auth != null
          && request.auth.token.admin == true;
    }

    // ─── raffles ──────────────────────────────────────────────────────────
    match /raffles/{raffleId} {

      // Catálogo público: cualquiera puede leer
      allow read: if true;

      // Solo el admin puede crear o eliminar rifas
      allow create, delete: if isAdmin();

      // Admin: puede actualizar cualquier campo
      // Público: puede actualizar ÚNICAMENTE campos del sorteo automático
      //   (el timer en la página pública ejecuta el sorteo cuando llega la hora)
      allow update: if isAdmin() || isPublicDrawUpdate();
    }

    // El usuario público solo puede tocar campos del resultado del sorteo,
    // y solo puede transicionar a estados válidos.
    function isPublicDrawUpdate() {
      let drawFields = [
        'drawStatus',
        'drawExecutedAt',
        'drawOutcome',
        'drawWinnerNumber',
        'drawWinnerName',
        'drawWinnerPhone'
      ];
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(drawFields)
          && request.resource.data.drawStatus in ['drawing', 'completed']
          && (
               request.resource.data.drawWinnerNumber == null
               || request.resource.data.drawWinnerNumber is number
             );
    }

    // ─── tickets ──────────────────────────────────────────────────────────
    match /tickets/{ticketId} {

      // Grilla de números: cualquiera puede leer
      allow read: if true;

      // Admin: acceso total a crear, actualizar y eliminar
      allow create, update, delete: if isAdmin();

      // Público - crear: solo cuando inicializa tickets vacíos (seed)
      //   Todos los campos de comprador deben ser null, status = 'available'
      allow create: if isPublicTicketSeed();

      // Público - actualizar: solo para registrar una compra
      //   El ticket debe pasar de available a reserved sin persistir PII
      allow update: if isPublicTicketPurchase();

      // Público nunca puede eliminar tickets
      allow delete: if false;
    }

    // Ticket seed: el visitante puede crear tickets solo en estado inicial limpio
    function isPublicTicketSeed() {
      let d = request.resource.data;
      return d.status == 'available'
          && d.userId    == null
          && d.userName  == null
          && d.userNationalId == null
          && d.userPhone == null
          && d.paymentRef == null
          && d.purchasedAt == null
          && d.keys().hasAll([
               'raffleId', 'number', 'status',
               'userId', 'userName', 'userNationalId',
               'userPhone', 'paymentRef', 'purchasedAt'
             ]);
    }

    // Ticket purchase: el visitante reserva un ticket disponible
    //   - Debe venir de 'available' → 'reserved'
    //   - Solo puede modificar status, orderId y purchasedAt
    //   - Los campos PII del ticket deben permanecer null
    function isPublicTicketPurchase() {
      let before = resource.data;
      let after  = request.resource.data;
      let purchaseFields = [
        'status', 'orderId', 'purchasedAt'
      ];
      return before.status == 'available'
          && after.status  == 'reserved'
          && after.diff(before).affectedKeys().hasOnly(purchaseFields)
          && after.orderId        is string && after.orderId.size()        > 0
          && after.purchasedAt    is string && after.purchasedAt.size()    > 0
          && after.userId    == null
          && after.userName  == null
          && after.userNationalId == null
          && after.userPhone == null
          && after.paymentRef == null;
    }

    // ─── orders ──────────────────────────────────────────────────────────
    match /orders/{orderId} {

      // Solo admin puede leer, actualizar o eliminar órdenes
      allow read, update, delete: if isAdmin();

      // Público: puede crear una orden nueva en estado reservado
      allow create: if request.resource.data.status == 'reserved'
          && request.resource.data.orderId is string
          && request.resource.data.orderId.size() > 0
          && request.resource.data.raffleId is string
          && request.resource.data.raffleId.size() > 0
          && request.resource.data.raffleTitle is string
          && request.resource.data.raffleTitle.size() > 0
          && request.resource.data.numbers is list
          && request.resource.data.numbers.size() > 0
          && request.resource.data.quantity is int
          && request.resource.data.quantity > 0
          && request.resource.data.customerName is string
          && request.resource.data.customerName.size() > 0
          && request.resource.data.customerNationalId is string
          && request.resource.data.customerNationalId.size() > 0
          && request.resource.data.customerPhone is string
          && request.resource.data.customerPhone.size() > 0
          && request.resource.data.paymentRef is string
          && request.resource.data.paymentRef.size() > 0
          && request.resource.data.createdAt is string
          && request.resource.data.createdAt.size() > 0;
    }

    // ─── raffleCertificates ─────────────────────────────────────────────
    match /raffleCertificates/{certificateId} {

      // Verificación pública del certificado
      allow read: if true;

      // Solo admin puede emitir o modificar certificados
      allow create, update, delete: if isAdmin();
    }
  }
}
